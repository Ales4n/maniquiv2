{% comment %} MANIQUI: Página de contacto — datos NAP + formulario + CTA WhatsApp — 2026-06-02 {% endcomment %}

{%- assign wa_phone = '34603305566' -%}
{%- assign wa_msg = 'Hola, necesito arreglar una prenda. ¿Me podéis dar precio?' | url_encode -%}
{%- assign wa_url = 'https://wa.me/' | append: wa_phone | append: '?text=' | append: wa_msg -%}

<section class="pco" id="paginaContacto" aria-labelledby="pco-headline">

  {%- comment %} Cabecera {%- endcomment %}
  <div class="pco__header">
    <div class="pco__header-inner maniqui-container">
      {%- if section.settings.eyebrow != blank -%}
        <p class="maniqui-eyebrow pco__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="pco__headline" id="pco-headline">{{ section.settings.headline }}</h1>
      {%- if section.settings.subhead != blank -%}
        <p class="pco__subhead">{{ section.settings.subhead }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment %} Cuerpo: 2 columnas {%- endcomment %}
  <div class="pco__body maniqui-container">

    {%- comment %} Columna izquierda — datos de contacto {%- endcomment %}
    <div class="pco__info">

      <div class="pco__info-block">
        <p class="pco__info-label">{{ section.settings.address_label }}</p>
        <p class="pco__info-text">{{ section.settings.address_street }}</p>
        <p class="pco__info-text">{{ section.settings.address_city }}</p>
        <a
          href="https://maps.google.com/?q={{ section.settings.address_street | append: ', ' | append: section.settings.address_city | url_encode }}"
          class="pco__map-link"
          target="_blank"
          rel="noopener"
        >{{ section.settings.map_link_label }} →</a>
      </div>

      <div class="pco__info-block">
        <p class="pco__info-label">{{ section.settings.hours_label }}</p>
        <p class="pco__info-text">{{ section.settings.hours_text }}</p>
        <p class="pco__info-subtext">{{ section.settings.hours_note }}</p>
      </div>

      <a
        href="{{ wa_url }}"
        class="pco__wa-btn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="{{ section.settings.wa_label | escape }} (abre WhatsApp)"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zm-5.421 7.403h-.004a10.87 10.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a10.86 10.86 0 01-1.184-5.37c.002-5.898 4.803-10.697 10.706-10.697 2.86 0 5.54 1.115 7.552 3.13a10.635 10.635 0 013.126 7.566c-.002 5.897-4.803 10.696-10.7 10.696z"/>
        </svg>
        {{- section.settings.wa_label -}}
      </a>

      <a href="mailto:{{ section.settings.email }}" class="pco__email-link">
        {{ section.settings.email }}
      </a>

      <div class="pco__internal-links">
        <a href="{{ section.settings.link_precios_url }}" class="pco__internal-link">{{ section.settings.link_precios_label }} →</a>
        <a href="{{ section.settings.link_contratar_url }}" class="pco__internal-link">{{ section.settings.link_contratar_label }} →</a>
      </div>

    </div>

    {%- comment %} Columna derecha — formulario {%- endcomment %}
    <div class="pco__form-wrap">
      <p class="pco__form-title">{{ section.settings.form_title }}</p>

      {%- if form.posted_successfully? -%}
        <div class="pco__success" role="status">
          <p>{{ section.settings.form_success }}</p>
        </div>
      {%- endif -%}

      {% form 'contact' %}
        {%- if form.errors -%}
          <div class="pco__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="pco__field">
          <label class="pco__label" for="pco-name">{{ section.settings.field_name_label }}</label>
          <input
            class="pco__input"
            type="text"
            id="pco-name"
            name="contact[name]"
            autocomplete="name"
            value="{{ form.name }}"
            required
          >
        </div>

        <div class="pco__field">
          <label class="pco__label" for="pco-email">{{ section.settings.field_email_label }}</label>
          <input
            class="pco__input"
            type="email"
            id="pco-email"
            name="contact[email]"
            autocomplete="email"
            value="{{ form.email }}"
            required
          >
        </div>

        <div class="pco__field">
          <label class="pco__label" for="pco-message">{{ section.settings.field_message_label }}</label>
          <textarea
            class="pco__input pco__textarea"
            id="pco-message"
            name="contact[body]"
            rows="5"
            required
          >{{ form.body }}</textarea>
        </div>

        <button type="submit" class="pco__submit">
          {{ section.settings.form_submit_label }}
        </button>
      {% endform %}
    </div>

  </div>
</section>

