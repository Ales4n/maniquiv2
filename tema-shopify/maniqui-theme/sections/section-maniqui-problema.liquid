{% comment %} MANIQUI: Problema·Solución — gancho emocional, conexión campaña Meta — 2026-05-04 {% endcomment %}

{%- liquid
  assign wa_number = settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-'
  assign wa_message = settings.whatsapp_message | url_encode
  assign wa_url = 'https://wa.me/' | append: wa_number | append: '?text=' | append: wa_message
-%}

<section class="mprob" id="maniquiProblema">
  <div class="mprob__inner maniqui-container">

    {%- comment %} Imagen izquierda {%- endcomment %}
    <div class="mprob__media">
      {%- if section.settings.image -%}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '450, 600, 900',
            sizes: '(max-width: 600px) 100vw, (max-width: 1024px) 45vw, 540px',
            class: 'mprob__img',
            alt: section.settings.image.alt | escape
        }}
      {%- else -%}
        <div class="mprob__img-placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    {%- comment %} Texto derecha {%- endcomment %}
    <div class="mprob__text">
      <p class="maniqui-eyebrow mprob__eyebrow">{{ section.settings.eyebrow }}</p>
      <span class="maniqui-sep-line mprob__sep"></span>
      <h2 class="mprob__headline">{{ section.settings.headline }}</h2>
      <p class="mprob__body">{{ section.settings.body }}</p>

      {%- if section.blocks.size > 0 -%}
        <ul class="mprob__tags" role="list" aria-label="Tipos de arreglo">
          {%- for block in section.blocks -%}
            {%- if block.type == 'tag' -%}
              <li class="mprob__tag" {{ block.shopify_attributes }}>{{ block.settings.label }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <a
        class="maniqui-btn maniqui-btn--wa mprob__cta"
        href="{{ wa_url }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="{{ section.settings.cta_label | escape }} (abre WhatsApp)"
      >
        <svg class="maniqui-icon-wa" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.6 6.32A8 8 0 0 0 4.45 16.4L4 20l3.74-1A8 8 0 1 0 17.6 6.32Zm-5.6 12a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.22.58.6-2.16-.16-.25a6.64 6.64 0 1 1 5.38 2.9Zm3.62-4.96c-.2-.1-1.18-.58-1.36-.65s-.32-.1-.45.1-.5.65-.62.78-.23.15-.43.05a5.42 5.42 0 0 1-1.6-1 6 6 0 0 1-1.1-1.38c-.12-.2 0-.3.08-.4s.2-.23.3-.34a1.34 1.34 0 0 0 .2-.34.37.37 0 0 0 0-.35c-.05-.1-.45-1.08-.62-1.48s-.33-.34-.45-.34h-.38a.74.74 0 0 0-.54.25 2.25 2.25 0 0 0-.7 1.67 3.9 3.9 0 0 0 .82 2.08 8.94 8.94 0 0 0 3.42 3.02c.48.2.85.32 1.14.41a2.76 2.76 0 0 0 1.26.08 2.06 2.06 0 0 0 1.36-.96 1.69 1.69 0 0 0 .12-.96c-.05-.08-.18-.13-.38-.23Z"/>
        </svg>
        {{ section.settings.cta_label }}
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Problema · Solución",
  "tag": "div",
  "class": "section-maniqui-prob",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen (antes/después o detalle de arreglo)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Lo que más nos pedís"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Titular",
      "default": "Compraste online y la prenda no te queda como esperabas."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Texto",
      "default": "Bajos largos, mangas que sobran, una cintura que pide ajuste. No hace falta devolver — un arreglo bien hecho lo cambia todo."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Etiqueta botón WhatsApp",
      "default": "Cuéntanos tu caso"
    }
  ],
  "blocks": [
    {
      "type": "tag",
      "name": "Etiqueta de arreglo",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "default": "Bajos"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Problema · Solución",
      "blocks": [
        { "type": "tag", "settings": { "label": "Bajos" } },
        { "type": "tag", "settings": { "label": "Cintura" } },
        { "type": "tag", "settings": { "label": "Mangas" } },
        { "type": "tag", "settings": { "label": "Hombros" } },
        { "type": "tag", "settings": { "label": "Camisas" } }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
/* ─── Problema·Solución ─── */
.section-maniqui-prob .mprob {
  background: var(--cream-warm);
  padding: 120px 0;
}

.section-maniqui-prob .mprob__inner {
  display: grid;
  grid-template-columns: 55fr 45fr;
  gap: 80px;
  align-items: center;
}

/* Imagen */
.section-maniqui-prob .mprob__media {
  position: relative;
  border-radius: 4px;
  overflow: hidden;
  aspect-ratio: 4 / 5;
}
.section-maniqui-prob .mprob__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.section-maniqui-prob .mprob__img-placeholder {
  width: 100%;
  height: 100%;
  background: var(--border);
}

/* Texto */
.section-maniqui-prob .mprob__text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
}

.section-maniqui-prob .mprob__eyebrow {
  margin-bottom: 16px;
}

.section-maniqui-prob .mprob__sep {
  margin-bottom: 24px;
}

.section-maniqui-prob .mprob__headline {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(28px, 3.2vw, 44px);
  line-height: 1.15;
  letter-spacing: -0.01em;
  color: var(--warm-dark);
  margin-bottom: 20px;
}

.section-maniqui-prob .mprob__body {
  font-size: 16px;
  color: var(--text-2);
  line-height: 1.7;
  margin-bottom: 32px;
  max-width: 42ch;
}

/* Tags */
.section-maniqui-prob .mprob__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  list-style: none;
  padding: 0;
  margin: 0 0 40px;
}
.section-maniqui-prob .mprob__tag {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--warm-dark);
  border: 1px solid var(--sage-line);
  border-radius: 999px;
  padding: 6px 14px;
  background: transparent;
  transition: background var(--tr-fast), border-color var(--tr-fast);
}

/* CTA — hereda padding de .maniqui-btn (14px 28px) */
.section-maniqui-prob .mprob__cta {
  border-radius: 999px;
}

/* ─── Tablet ─── */
@media (max-width: 1024px) {
  .section-maniqui-prob .mprob {
    padding: 80px 0;
  }
  .section-maniqui-prob .mprob__inner {
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
}

/* ─── Mobile ─── */
@media (max-width: 600px) {
  .section-maniqui-prob .mprob {
    padding: 64px 0;
  }
  .section-maniqui-prob .mprob__inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .section-maniqui-prob .mprob__media {
    aspect-ratio: 3 / 2;
    order: 1;
  }
  .section-maniqui-prob .mprob__text {
    order: 0;
  }
  .section-maniqui-prob .mprob__body {
    max-width: 100%;
  }
  .section-maniqui-prob .mprob__cta {
    width: 100%;
    justify-content: center;
  }
}
{% endstylesheet %}
