{% comment %} MANIQUI: Problema·Solución — gancho emocional, conexión campaña Meta — 2026-05-04 {% endcomment %}
{% comment %} MANIQUI: Auditoría WA — botón verde eliminado, tags pasan a anchors — 2026-05-16 {% endcomment %}

<section class="mprob" id="maniquiProblema">
  <div class="mprob__inner maniqui-container">

    {%- comment %} Imagen izquierda {%- endcomment %}
    <div class="mprob__media">
      {%- if section.settings.image -%}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '450, 600, 900',
            sizes: '(max-width: 600px) 100vw, (max-width: 1024px) 45vw, 540px',
            class: 'mprob__img',
            alt: section.settings.image.alt | escape
        }}
      {%- else -%}
        <div class="mprob__img-placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    {%- comment %} Texto derecha {%- endcomment %}
    <div class="mprob__text">
      <p class="maniqui-eyebrow mprob__eyebrow">{{ section.settings.eyebrow }}</p>
      <span class="maniqui-sep-line mprob__sep"></span>
      <h2 class="mprob__headline">{{ section.settings.headline }}</h2>
      <p class="mprob__body">{{ section.settings.body }}</p>

      {%- if section.blocks.size > 0 -%}
        <ul class="mprob__tags" role="list" aria-label="Tipos de arreglo">
          {%- for block in section.blocks -%}
            {%- if block.type == 'tag' -%}
              {%- assign tag_url = block.settings.url | default: '#maniquiCanales' -%}
              <li class="mprob__tag" {{ block.shopify_attributes }}>
                <a class="mprob__tag-link" href="{{ tag_url }}">{{ block.settings.label }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Problema · Solución",
  "tag": "div",
  "class": "section-maniqui-prob",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen (antes/después o detalle de arreglo)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Lo que más nos pedís"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Titular",
      "default": "Compraste online y la prenda no te queda como esperabas."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Texto",
      "default": "Bajos largos, mangas que sobran, una cintura que pide ajuste. No hace falta devolver — un arreglo bien hecho lo cambia todo."
    }
  ],
  "blocks": [
    {
      "type": "tag",
      "name": "Etiqueta de arreglo",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "default": "Bajos"
        },
        {
          "type": "text",
          "id": "url",
          "label": "URL (vacío → ancla a sección Canales)",
          "info": "Ej: /collections/bajos-pantalon o #maniquiCanales"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Problema · Solución",
      "blocks": [
        { "type": "tag", "settings": { "label": "Bajos" } },
        { "type": "tag", "settings": { "label": "Cintura" } },
        { "type": "tag", "settings": { "label": "Mangas" } },
        { "type": "tag", "settings": { "label": "Hombros" } },
        { "type": "tag", "settings": { "label": "Camisas" } }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
/* ─── Problema·Solución ─── */
.section-maniqui-prob .mprob {
  background: var(--cream-warm);
  padding: 120px 0;
}

.section-maniqui-prob .mprob__inner {
  display: grid;
  grid-template-columns: 55fr 45fr;
  gap: 80px;
  align-items: center;
}

/* Imagen */
.section-maniqui-prob .mprob__media {
  position: relative;
  border-radius: 4px;
  overflow: hidden;
  aspect-ratio: 4 / 5;
}
.section-maniqui-prob .mprob__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.section-maniqui-prob .mprob__img-placeholder {
  width: 100%;
  height: 100%;
  background: var(--border);
}

/* Texto */
.section-maniqui-prob .mprob__text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  align-self: center;
  gap: 0;
}

.section-maniqui-prob .mprob__eyebrow {
  margin-bottom: 16px;
}

.section-maniqui-prob .mprob__sep {
  margin-bottom: 24px;
}

.section-maniqui-prob .mprob__headline {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(28px, 3.2vw, 44px);
  line-height: 1.15;
  letter-spacing: -0.01em;
  color: var(--warm-dark);
  margin-bottom: 20px;
}

.section-maniqui-prob .mprob__body {
  font-size: 16px;
  color: var(--text-2);
  line-height: 1.7;
  margin-bottom: 32px;
  max-width: 42ch;
}

/* Tags clicables */
.section-maniqui-prob .mprob__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  list-style: none;
  padding: 0;
  margin: 0;
}

.section-maniqui-prob .mprob__tag {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--warm-dark);
  border: 1px solid var(--sage-line);
  border-radius: 999px;
  padding: 6px 14px;
  background: transparent;
  transition: background var(--tr-fast), border-color var(--tr-fast);
}

.section-maniqui-prob .mprob__tag:hover {
  background: var(--sage-soft);
  border-color: var(--sage);
  cursor: pointer;
}

.section-maniqui-prob .mprob__tag-link {
  display: block;
  color: inherit;
  font: inherit;
  text-decoration: none;
}

/* ─── Tablet ─── */
@media (max-width: 1024px) {
  .section-maniqui-prob .mprob {
    padding: 80px 0;
  }
  .section-maniqui-prob .mprob__inner {
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
}

/* ─── Mobile ─── */
@media (max-width: 600px) {
  .section-maniqui-prob .mprob {
    padding: 64px 0;
  }
  .section-maniqui-prob .mprob__inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .section-maniqui-prob .mprob__media {
    aspect-ratio: 3 / 2;
    order: 1;
  }
  .section-maniqui-prob .mprob__text {
    order: 0;
  }
  .section-maniqui-prob .mprob__body {
    max-width: 100%;
  }
}
{% endstylesheet %}
