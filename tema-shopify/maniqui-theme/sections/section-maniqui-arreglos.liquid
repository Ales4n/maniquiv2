{% comment %} MANIQUI: Arreglos más pedidos — 4 cols desktop, 2x2 tablet, snap mobile — 2026-05-05 {% endcomment %}

<section class="marr" id="maniquiArreglos">
  <div class="marr__inner maniqui-container">

    <header class="marr__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="maniqui-eyebrow marr__eyebrow">{{ section.settings.eyebrow }}</p>
        <span class="maniqui-sep-line marr__sep"></span>
      {%- endif -%}
      <h2 class="marr__headline">
        {{ section.settings.headline }}
        {%- if section.settings.headline_em != blank -%}
          <em class="marr__headline-em">{{ section.settings.headline_em }}</em>
        {%- endif -%}
      </h2>
      {%- if section.settings.subheadline != blank -%}
        <p class="marr__sub">{{ section.settings.subheadline }}</p>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="marr__grid-wrap">
        <div class="marr__grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'arreglo' -%}
              <article class="marr__card" {{ block.shopify_attributes }}>

                <div class="marr__card-img-wrap">
                  {%- if block.settings.image -%}
                    {% render 'responsive-image',
                        image: block.settings.image,
                        image_mobile: block.settings.image_mobile,
                        alt: block.settings.headline | escape,
                        class: 'marr__card-img',
                        loading: 'lazy',
                        sizes: '(max-width: 600px) 72vw, (max-width: 1024px) 45vw, 280px',
                        widths: '300, 400, 600' %}
                  {%- else -%}
                    <div class="marr__card-img-placeholder" aria-hidden="true"></div>
                  {%- endif -%}
                  <span class="marr__card-tag" aria-hidden="true">{{ block.settings.headline }}</span>
                </div>

                <div class="marr__card-content">
                  <div class="marr__card-top">
                    <h3 class="marr__card-title">{{ block.settings.headline }}</h3>
                    {%- if block.settings.price != blank -%}
                      <p class="marr__card-price">{{ block.settings.price }}</p>
                    {%- endif -%}
                  </div>
                  {%- if block.settings.body != blank -%}
                    <p class="marr__card-body">{{ block.settings.body }}</p>
                  {%- endif -%}
                  {%- if block.settings.url != blank -%}
                    <a class="marr__card-link" href="{{ block.settings.url }}" aria-label="Ver arreglo: {{ block.settings.headline | escape }}">
                      Ver arreglo
                      <svg class="marr__card-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                      </svg>
                    </a>
                  {%- endif -%}
                </div>

              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <div class="marr__footer">
        <a class="maniqui-btn maniqui-btn--outline-dark marr__cta" href="{{ section.settings.cta_url }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

