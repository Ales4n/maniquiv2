{% comment %} MANIQUI: Cursos · Formato + datos prácticos + CTA final WA propio — 2026-06-20 {% endcomment %}

{%- liquid
  assign wa_number  = settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-'
  assign wa_message = section.settings.wa_message_curso | url_encode
  assign wa_url     = 'https://wa.me/' | append: wa_number | append: '?text=' | append: wa_message
-%}

<section class="pcf" id="cursosFormato" aria-labelledby="pcf-headline">
  <div class="pcf__inner maniqui-container">

    <header class="pcf__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="maniqui-eyebrow pcf__eyebrow">{{ section.settings.eyebrow }}</p>
        <span class="maniqui-sep-line pcf__sep" aria-hidden="true"></span>
      {%- endif -%}
      <h2 class="pcf__headline" id="pcf-headline">
        {{ section.settings.headline }}
        {%- if section.settings.headline_em != blank -%}
          <em class="pcf__headline-em">{{ section.settings.headline_em }}</em>
        {%- endif -%}
      </h2>
    </header>

    {%- if section.settings.autoridad != blank -%}
      <div class="pcf__autoridad">{{ section.settings.autoridad }}</div>
    {%- endif -%}

    <!-- ── Datos prácticos ── -->
    {%- if section.blocks.size > 0 -%}
      <dl class="pcf__datos">
        {%- if section.settings.fecha_inicio != blank -%}
          <div class="pcf__dato pcf__dato--fecha">
            <dt class="pcf__dato-label">Próxima fecha</dt>
            <dd class="pcf__dato-valor">{{ section.settings.fecha_inicio }}</dd>
          </div>
        {%- endif -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'dato' -%}
            <div class="pcf__dato" {{ block.shopify_attributes }}>
              <dt class="pcf__dato-label">{{ block.settings.label }}</dt>
              <dd class="pcf__dato-valor">{{ block.settings.valor }}</dd>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </dl>
    {%- endif -%}

    <!-- ── CTA final ── -->
    <div class="pcf__cta-block">
      {%- if section.settings.cta_headline != blank -%}
        <p class="pcf__cta-headline">{{ section.settings.cta_headline }}</p>
      {%- endif -%}
      <div class="pcf__ctas">
        {%- if section.settings.cta_primary_label != blank and section.settings.cta_primary_url != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="maniqui-btn pcf__cta-primary">
            {{ section.settings.cta_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a
            href="{{ wa_url }}"
            class="pcf__cta-wa"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="{{ section.settings.cta_label | escape }}"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.6 6.32A8 8 0 0 0 4.45 16.4L4 20l3.74-1A8 8 0 1 0 17.6 6.32Zm-5.6 12a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.22.58.6-2.16-.16-.25a6.64 6.64 0 1 1 5.38 2.9Zm3.62-4.96c-.2-.1-1.18-.58-1.36-.65s-.32-.1-.45.1-.5.65-.62.78-.23.15-.43.05a5.42 5.42 0 0 1-1.6-1 6 6 0 0 1-1.1-1.38c-.12-.2 0-.3.08-.4s.2-.23.3-.34a1.34 1.34 0 0 0 .2-.34.37.37 0 0 0 0-.35c-.05-.1-.45-1.08-.62-1.48s-.33-.34-.45-.34h-.38a.74.74 0 0 0-.54.25 2.25 2.25 0 0 0-.7 1.67 3.9 3.9 0 0 0 .82 2.08 8.94 8.94 0 0 0 3.42 3.02c.48.2.85.32 1.14.41a2.76 2.76 0 0 0 1.26.08 2.06 2.06 0 0 0 1.36-.96 1.69 1.69 0 0 0 .12-.96c-.05-.08-.18-.13-.38-.23Z"/>
            </svg>
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Cursos · Formato",
  "tag": "div",
  "class": "section-page-cursos-formato",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "PRÁCTICO"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Titular (antes del énfasis)",
      "default": "Cómo"
    },
    {
      "type": "text",
      "id": "headline_em",
      "label": "Titular énfasis (cursiva sage)",
      "default": "funciona"
    },
    {
      "type": "richtext",
      "id": "autoridad",
      "label": "Frase de autoridad",
      "default": "<p>Te enseñan Saydith, Ana y Esperanza — las mismas manos que arreglan la ropa de medio Marxalenes.</p>"
    },
    {
      "type": "text",
      "id": "fecha_inicio",
      "label": "Próxima fecha (editar en cada tanda)",
      "info": "Deja vacío para ocultar este campo.",
      "default": "Sábado 4 de julio"
    },
    {
      "type": "text",
      "id": "cta_headline",
      "label": "Titular del bloque CTA",
      "default": "¿Te apuntas?"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Texto del botón primario (inscripción)",
      "default": "Reservar plaza"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "URL del botón primario",
