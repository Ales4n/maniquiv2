      "info": "⚠️ No usar el mensaje global de arreglos — este es específico del curso.",
      "default": "Hola, me interesa el curso de costura. ¿Me dais más información?"
    }
  ],
  "blocks": [
    {
      "type": "dato",
      "name": "Dato práctico",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "Etiqueta"
        },
        {
          "type": "text",
          "id": "valor",
          "label": "Valor",
          "default": "—"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cursos · Formato",
      "settings": {
        "eyebrow": "PRÁCTICO",
        "headline": "Cómo",
        "headline_em": "funciona",
        "autoridad": "<p>Te enseñan Saydith, Ana y Esperanza — las mismas manos que arreglan la ropa de medio Marxalenes.</p>",
