{% stylesheet %}
/* ─── Cursos · Formato ─── */
.section-page-cursos-formato .pcf {
  background: var(--cream-warm);
  padding: 96px 0;
}
.section-page-cursos-formato .pcf__inner {
  max-width: var(--container-max);
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 56px;
}

/* ─── Header ─── */
.section-page-cursos-formato .pcf__header {
  text-align: center;
  max-width: 560px;
  margin: 0 auto;
}
.section-page-cursos-formato .pcf__eyebrow {
  margin-bottom: 16px;
}
.section-page-cursos-formato .pcf__sep {
  display: block;
  margin-bottom: 24px;
}
.section-page-cursos-formato .pcf__headline {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(2rem, 3.5vw, 3rem);
  line-height: 1.1;
  letter-spacing: -0.01em;
  color: var(--warm-dark);
  margin: 0;
}
.section-page-cursos-formato .pcf__headline-em {
  font-style: italic;
  color: var(--sage);
}

/* ─── Frase de autoridad ─── */
.section-page-cursos-formato .pcf__autoridad {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.125rem, 2vw, 1.375rem);
  line-height: 1.5;
  color: var(--sage-dark);
  text-align: center;
  max-width: 56ch;
  margin: 0 auto;
}
.section-page-cursos-formato .pcf__autoridad p { margin: 0; }

/* ─── Datos prácticos ─── */
.section-page-cursos-formato .pcf__datos {
  margin: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  background: var(--cream);
}
.section-page-cursos-formato .pcf__dato {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 24px 28px;
  border-bottom: 1px solid var(--border);
}
.section-page-cursos-formato .pcf__dato:nth-child(odd) {
  border-right: 1px solid var(--border);
}
.section-page-cursos-formato .pcf__dato:nth-last-child(-n+2):not(:only-child) {
  border-bottom: none;
}
.section-page-cursos-formato .pcf__dato--fecha {
  grid-column: 1 / -1;
  background: var(--sage-soft);
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.section-page-cursos-formato .pcf__dato-label {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
}
.section-page-cursos-formato .pcf__dato-valor {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 500;
  color: var(--warm-dark);
  margin: 0;
}
.section-page-cursos-formato .pcf__dato--fecha .pcf__dato-label {
  color: var(--sage-dark);
}
.section-page-cursos-formato .pcf__dato--fecha .pcf__dato-valor {
  font-size: 16px;
  color: var(--warm-dark);
}

/* ─── CTA final ─── */
.section-page-cursos-formato .pcf__cta-block {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
  padding: 48px 0 0;
  border-top: 1px solid var(--border);
}
.section-page-cursos-formato .pcf__cta-headline {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  color: var(--warm-dark);
  margin: 0;
  letter-spacing: -0.01em;
}
.section-page-cursos-formato .pcf__ctas {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.section-page-cursos-formato .pcf__cta-primary {
  background: var(--sage);
  color: var(--cream);
  border-color: var(--sage);
  min-width: 220px;
  justify-content: center;
}
.section-page-cursos-formato .pcf__cta-primary:hover {
  background: var(--sage-dark);
  border-color: var(--sage-dark);
  color: var(--cream);
  transform: translateY(-1px);
}
.section-page-cursos-formato .pcf__cta-wa {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  color: var(--text-2);
  text-decoration: none;
  transition: color 200ms ease;
}
.section-page-cursos-formato .pcf__cta-wa:hover { color: var(--warm-dark); }
.section-page-cursos-formato .pcf__cta-wa svg { color: #25d366; flex-shrink: 0; }

/* ─── Tablet ─── */
@media (max-width: 1024px) {
  .section-page-cursos-formato .pcf {
    padding: 80px 0;
  }
  .section-page-cursos-formato .pcf__inner {
    gap: 48px;
  }
}

/* ─── Mobile ─── */
@media (max-width: 600px) {
  .section-page-cursos-formato .pcf {
    padding: 64px 0;
  }
  .section-page-cursos-formato .pcf__datos {
    grid-template-columns: 1fr;
  }
  .section-page-cursos-formato .pcf__dato:nth-child(odd) {
    border-right: none;
  }
  .section-page-cursos-formato .pcf__dato:nth-last-child(-n+2):not(:only-child) {
    border-bottom: 1px solid var(--border);
  }
  .section-page-cursos-formato .pcf__dato:last-child {
    border-bottom: none;
  }
  .section-page-cursos-formato .pcf__dato--fecha {
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }
  .section-page-cursos-formato .pcf__cta-primary {
    width: 100%;
    min-width: 0;
  }
}
{% endstylesheet %}
