{% comment %} MANIQUI: Cart page — /cart — lista de prendas + checkout — 2026-06-12 {% endcomment %}

<section class="mcp" id="cartPage">
  <div class="mcp__inner maniqui-container">

    <h1 class="mcp__title">Tu carrito</h1>

    <div class="mcp__layout">
      <div id="mcpItems" class="mcp__items">
        <!-- renderizado via JS -->
      </div>

      <aside class="mcp__sidebar" id="mcpSidebar" hidden>
        <div class="mcp__summary">
          <div class="mcp__summary-row mcp__total-row">
            <span>Total</span>
            <span id="mcpTotal"></span>
          </div>
          <a href="/checkout" class="maniqui-btn mcp__checkout-btn">
            Pagar
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
          <a href="/pages/contratar" class="mcp__add-more">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M12 5v14M5 12h14"/>
            </svg>
            Añadir otra prenda
          </a>
        </div>
      </aside>
    </div>

  </div>
</section>

<script>
(function () {
  var itemsEl  = document.getElementById('mcpItems');
  var sidebarEl = document.getElementById('mcpSidebar');
  var totalEl  = document.getElementById('mcpTotal');

  function formatMoney(cents) {
    return (cents / 100).toLocaleString('es-ES', { style: 'currency', currency: 'EUR' });
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function loadCart() {
    fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        if (!itemsEl) return;

        if (!cart.items || cart.items.length === 0) {
          itemsEl.innerHTML = '<div class="mcp__empty">'
            + '<p>Tu carrito está vacío.</p>'
            + '<a href="/pages/contratar" class="maniqui-btn">Ver arreglos</a>'
            + '</div>';
          if (sidebarEl) sidebarEl.hidden = true;
          return;
        }

        var html = '';
        cart.items.forEach(function (item) {
          var fotoUrl   = item.properties && item.properties['Foto'];
          var instrText = item.properties && item.properties['Instrucciones'];

          var thumbHtml;
          if (fotoUrl && /^https?:\/\//.test(fotoUrl)) {
            thumbHtml = '<img src="' + escapeHtml(fotoUrl) + '" alt="Foto prenda" loading="lazy">';
          } else {
            thumbHtml = '<div class="mcp__item-thumb-placeholder">'
              + '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 16l5-5 4 4 3-3 6 6"/></svg>'
              + '</div>';
          }

          var instrHtml = instrText
            ? '<p class="mcp__item-instrucciones">' + escapeHtml(instrText) + '</p>'
            : '';

          html += '<div class="mcp__item">'
            + '<div class="mcp__item-thumb">' + thumbHtml + '</div>'
            + '<div class="mcp__item-info">'
            + '<p class="mcp__item-title">' + escapeHtml(item.product_title) + '</p>'
            + instrHtml
            + '<p class="mcp__item-price">' + formatMoney(item.final_line_price) + '</p>'
            + '</div>'
            + '<button class="mcp__item-remove" data-key="' + escapeHtml(item.key) + '" type="button" aria-label="Eliminar prenda">'
            + '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>'
            + '</button>'
            + '</div>';
        });

        itemsEl.innerHTML = html;
        if (totalEl) totalEl.textContent = formatMoney(cart.total_price);
        if (sidebarEl) sidebarEl.hidden = false;
      })
      .catch(function () {
        if (itemsEl) itemsEl.innerHTML = '<p class="mcp__empty">No se pudo cargar el carrito.</p>';
      });
  }

  if (itemsEl) {
    itemsEl.addEventListener('click', function (e) {
      var btn = e.target.closest('.mcp__item-remove');
      if (!btn) return;
      btn.disabled = true;
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: btn.dataset.key, quantity: 0 })
      }).then(function () { loadCart(); }).catch(function () { loadCart(); });
    });
  }

  loadCart();
})();
</script>

{% stylesheet %}
.section-maniqui-cart-page .mcp {
  background: var(--cream);
  padding: 64px 0 96px;
  min-height: 60vh;
}
.section-maniqui-cart-page .mcp__inner {
  max-width: var(--container-max);
  margin: 0 auto;
}
.section-maniqui-cart-page .mcp__title {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(2rem, 4vw, 2.75rem);
  color: var(--warm-dark);
  margin-bottom: 48px;
  line-height: 1.08;
}

/* ─── Layout ─── */
.section-maniqui-cart-page .mcp__layout {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 64px;
  align-items: start;
}

/* ─── Ítems ─── */
.section-maniqui-cart-page .mcp__item {
  display: flex;
  gap: 20px;
  align-items: flex-start;
  padding: 24px 0;
  border-bottom: 1px solid var(--border);
}
.section-maniqui-cart-page .mcp__item:first-child {
  border-top: 1px solid var(--border);
}
.section-maniqui-cart-page .mcp__item-thumb {
  width: 96px;
  height: 96px;
  border-radius: 8px;
  overflow: hidden;
  background: var(--cream-warm);
  flex-shrink: 0;
}
.section-maniqui-cart-page .mcp__item-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.section-maniqui-cart-page .mcp__item-thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
}
.section-maniqui-cart-page .mcp__item-info { flex: 1; min-width: 0; }
.section-maniqui-cart-page .mcp__item-title {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 500;
  color: var(--warm-dark);
  margin: 0 0 6px;
}
.section-maniqui-cart-page .mcp__item-instrucciones {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--text-muted);
  font-style: italic;
  margin: 0 0 10px;
  line-height: 1.5;
}
.section-maniqui-cart-page .mcp__item-price {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 600;
  color: var(--warm-dark);
  margin: 0;
}
.section-maniqui-cart-page .mcp__item-remove {
  flex-shrink: 0;
  align-self: flex-start;
  color: var(--text-muted);
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  display: flex;
  align-items: center;
  transition: color 200ms ease;
  margin-top: 2px;
}
.section-maniqui-cart-page .mcp__item-remove:hover { color: var(--terracotta); }
.section-maniqui-cart-page .mcp__item-remove:disabled { opacity: 0.35; cursor: not-allowed; }

/* ─── Vacío ─── */
.section-maniqui-cart-page .mcp__empty {
  text-align: center;
  padding: 80px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
  color: var(--text-muted);
  font-family: var(--font-body);
  font-size: 15px;
}

/* ─── Sidebar ─── */
.section-maniqui-cart-page .mcp__summary {
  background: var(--cream-warm);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: sticky;
  top: 24px;
}
.section-maniqui-cart-page .mcp__summary-row {
  display: flex;
  justify-content: space-between;
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--text-2);
}
.section-maniqui-cart-page .mcp__total-row {
  font-size: 16px;
  font-weight: 600;
  color: var(--warm-dark);
}
.section-maniqui-cart-page .mcp__checkout-btn {
  background: var(--warm-dark);
  color: var(--cream);
  border-color: var(--warm-dark);
  justify-content: center;
  width: 100%;
}
.section-maniqui-cart-page .mcp__checkout-btn:hover {
  background: #1d1916;
  border-color: #1d1916;
}
.section-maniqui-cart-page .mcp__add-more {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--sage-dark);
  text-decoration: none;
  transition: color 200ms ease;
}
.section-maniqui-cart-page .mcp__add-more:hover { color: var(--sage); }

/* ─── Tablet ─── */
@media (max-width: 900px) {
  .section-maniqui-cart-page .mcp__layout {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .section-maniqui-cart-page .mcp__summary {
    position: static;
  }
}

/* ─── Mobile ─── */
@media (max-width: 600px) {
  .section-maniqui-cart-page .mcp {
    padding: 40px 0 72px;
  }
  .section-maniqui-cart-page .mcp__item-thumb {
    width: 72px;
    height: 72px;
  }
}
{% endstylesheet %}

