{% comment %} MANIQUI: Footer global — NAP, navegación, redes + JSON-LD LocalBusiness — 2026-05-10 {% endcomment %}

{%- assign wa_phone = '34603305566' -%}
{%- assign wa_msg = 'Hola, necesito arreglar una prenda. ¿Me podéis dar precio?' | url_encode -%}
{%- assign wa_url = 'https://wa.me/' | append: wa_phone | append: '?text=' | append: wa_msg -%}
{%- assign current_year = 'now' | date: '%Y' -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Maniquí Creaciones",
  "url": {{ shop.url | json }},
  "telephone": "+34603305566",
  "email": "hola@maniquicreaciones.com",
  "image": {{ shop.url | append: '/assets/og-maniqui.jpg' | json }},
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Avinguda de la Constitució, 94",
    "addressLocality": "Valencia",
    "addressRegion": "Comunitat Valenciana",
    "postalCode": "46009",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 39.4832,
    "longitude": -0.3854
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "10:00",
      "closes": "14:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "17:00",
      "closes": "20:00"
    }
  ],
  "priceRange": "€€",
  "currenciesAccepted": "EUR",
  "areaServed": "Valencia, España"
}
</script>

<footer class="mfoot" id="maniquiFooter" role="contentinfo">
  <div class="mfoot__inner maniqui-container">

    <div class="mfoot__grid">

      <!-- Columna 1: Empresa + NAP -->
      <div class="mfoot__col mfoot__col--brand">
        <p class="mfoot__brand-name">{{ section.settings.brand_name }}</p>
        {%- if section.settings.brand_tagline != blank -%}
          <p class="mfoot__brand-tagline">{{ section.settings.brand_tagline }}</p>
        {%- endif -%}

        <address class="mfoot__address">
          {%- if section.settings.address_street != blank -%}
            <span class="mfoot__address-line">{{ section.settings.address_street }}</span>
          {%- endif -%}
          {%- if section.settings.address_city != blank -%}
            <span class="mfoot__address-line">{{ section.settings.address_city }}</span>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            {%- assign phone_href = section.settings.phone | remove: ' ' -%}
            <a href="tel:{{ phone_href }}" class="mfoot__phone">{{ section.settings.phone }}</a>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <a href="mailto:{{ section.settings.email }}" class="mfoot__email">{{ section.settings.email }}</a>
          {%- endif -%}
        </address>
      </div>

      <!-- Columna 2: Servicios -->
      <div class="mfoot__col">
        <p class="mfoot__col-title">{{ section.settings.col_servicios_title }}</p>
        {%- if section.settings.menu_servicios != blank -%}
          <ul class="mfoot__nav-list">
            {%- for link in linklists[section.settings.menu_servicios].links -%}
              <li><a href="{{ link.url }}" class="mfoot__nav-link">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <!-- Columna 3: Información -->
      <div class="mfoot__col">
        <p class="mfoot__col-title">{{ section.settings.col_info_title }}</p>
        {%- if section.settings.menu_info != blank -%}
          <ul class="mfoot__nav-list">
            {%- for link in linklists[section.settings.menu_info].links -%}
              <li><a href="{{ link.url }}" class="mfoot__nav-link">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <!-- Columna 4: Síguenos -->
      <div class="mfoot__col">
        <p class="mfoot__col-title">{{ section.settings.col_social_title }}</p>
        <ul class="mfoot__nav-list">
          {%- if section.settings.instagram_url != blank -%}
            <li>
              <a href="{{ section.settings.instagram_url }}" class="mfoot__nav-link" target="_blank" rel="noopener">
                Instagram
              </a>
            </li>
          {%- endif -%}
          <li>
            <a href="{{ wa_url }}" class="mfoot__nav-link mfoot__nav-link--wa" target="_blank" rel="noopener">
              WhatsApp
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mfoot__bottom">
      <p class="mfoot__legal">
        &copy; {{ current_year }} {{ section.settings.brand_name }}.
        {%- if section.settings.legal_tagline != blank -%}
          {{ section.settings.legal_tagline }}
        {%- endif -%}
      </p>
      <nav class="mfoot__legal-nav" aria-label="Legal">
        {%- if section.settings.privacy_url != blank -%}
          <a href="{{ section.settings.privacy_url }}" class="mfoot__legal-link">Política de privacidad</a>
        {%- endif -%}
        {%- if section.settings.cookies_url != blank -%}
          <a href="{{ section.settings.cookies_url }}" class="mfoot__legal-link">Cookies</a>
        {%- endif -%}
      </nav>
    </div>

  </div>
</footer>

