{% comment %} MANIQUI: Hero de "Sobre nosotras" — página interior, sin nav, sin CTAs — 2026-06-02 {% endcomment %}

{%- assign hero_alt = section.settings.image_alt | default: 'Saydith, Ana y Esperanza en el taller de Maniquí en Marxalenes, Valencia' -%}

<section class="snh" id="sobreNosotrasHero" aria-labelledby="snh-headline">

  <div class="snh__bg" role="presentation">
    {%- if section.settings.image -%}
      {% render 'responsive-image',
          image: section.settings.image,
          image_mobile: section.settings.image_mobile,
          alt: hero_alt,
          class: 'snh__bg-img',
          loading: 'eager',
          sizes: '100vw',
          widths: '750, 1080, 1440, 1920' %}
    {%- else -%}
      <div class="snh__bg-placeholder" aria-hidden="true"></div>
    {%- endif -%}
  </div>

  <div class="snh__content">
    <div class="snh__inner maniqui-container">
      {%- if section.settings.eyebrow != blank -%}
        <p class="maniqui-eyebrow snh__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="snh__headline" id="snh-headline">{{ section.settings.headline }}</h1>
      {%- if section.settings.subhead != blank -%}
        <p class="snh__subhead">{{ section.settings.subhead }}</p>
      {%- endif -%}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero Sobre Nosotras",
  "tag": "div",
  "class": "section-page-sobre-nosotras-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Imagen para móvil (opcional)",
      "info": "Si la subes, se muestra solo en móvil (≤749px). Si no, se usa la de escritorio."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alt text imagen",
      "default": "Saydith, Ana y Esperanza en el taller de Maniquí en Marxalenes, Valencia"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SOBRE NOSOTRAS"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "H1 — Titular principal",
      "default": "Tres modistas y un taller de arreglos en Valencia"
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subtítulo",
      "default": "Saydith, Ana y Esperanza llevan tres años cosiendo en su propio taller de Marxalenes. Sin intermediarios: ellas ven tu prenda y ellas la trabajan, de principio a fin."
    }
  ],
  "presets": [
    {
      "name": "Hero Sobre Nosotras"
    }
  ]
}
{% endschema %}

{% stylesheet %}
/* ─── Hero Sobre Nosotras ─── */
.section-page-sobre-nosotras-hero .snh {
  position: relative;
  min-height: 62vh;
  overflow: hidden;
  background: var(--warm-dark);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.section-page-sobre-nosotras-hero .snh__bg {
  position: absolute;
  inset: 0;
}
.section-page-sobre-nosotras-hero .snh__bg picture { display: block; width: 100%; height: 100%; }
.section-page-sobre-nosotras-hero .snh__bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  display: block;
}
.section-page-sobre-nosotras-hero .snh__bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(42, 37, 32, 0.48);
}
.section-page-sobre-nosotras-hero .snh__bg-placeholder {
  width: 100%;
  height: 100%;
  background: var(--warm-dark);
}

.section-page-sobre-nosotras-hero .snh__content {
  position: relative;
  z-index: 2;
  padding: 100px 0 80px;
}
.section-page-sobre-nosotras-hero .snh__inner {
  padding: 0 48px;
}

.section-page-sobre-nosotras-hero .snh__eyebrow {
  color: rgba(143, 165, 133, 0.9);
  margin-bottom: 16px;
}

.section-page-sobre-nosotras-hero .snh__headline {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(36px, 5.2vw, 72px);
  line-height: 1.08;
  letter-spacing: -0.01em;
  color: var(--cream);
  margin: 0 0 24px;
  max-width: 820px;
}

.section-page-sobre-nosotras-hero .snh__subhead {
  font-size: 17px;
  line-height: 1.6;
  color: rgba(253, 251, 247, 0.82);
  max-width: 560px;
  margin: 0;
}

/* ─── Tablet ─── */
@media (max-width: 1024px) {
  .section-page-sobre-nosotras-hero .snh__content {
    padding: 80px 0 64px;
  }
  .section-page-sobre-nosotras-hero .snh__inner {
    padding: 0 32px;
  }
}

/* ─── Mobile ─── */
@media (max-width: 600px) {
  .section-page-sobre-nosotras-hero .snh {
    min-height: 56vh;
  }
  .section-page-sobre-nosotras-hero .snh__content {
    padding: 80px 0 48px;
  }
  .section-page-sobre-nosotras-hero .snh__inner {
    padding: 0 24px;
  }
  .section-page-sobre-nosotras-hero .snh__headline {
    font-size: clamp(32px, 9vw, 48px);
    margin-bottom: 16px;
  }
  .section-page-sobre-nosotras-hero .snh__subhead {
    font-size: 15px;
  }
}
{% endstylesheet %}
