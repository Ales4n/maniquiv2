{% comment %} MANIQUI: Validación social — 3 reseñas Google + bloque estadística — 2026-05-16 {% endcomment %}

{%- assign google_url = section.settings.google_url | default: '#' -%}

<section class="mtesti" id="maniquiTestimonios">
  <div class="mtesti__inner maniqui-container">

    <header class="mtesti__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="maniqui-eyebrow mtesti__eyebrow">{{ section.settings.eyebrow }}</p>
        <span class="maniqui-sep-line mtesti__sep"></span>
      {%- endif -%}
      <h2 class="mtesti__headline">
        {{- section.settings.headline -}}{% if section.settings.headline_em != blank %} <em class="mtesti__headline-em">{{ section.settings.headline_em }}</em>{% endif %}{% if section.settings.headline_post != blank %} {{ section.settings.headline_post }}{% endif %}
      </h2>
      {%- if section.settings.subheadline != blank -%}
        <p class="mtesti__sub">{{ section.settings.subheadline }}</p>
      {%- endif -%}
    </header>

    <div class="mtesti__grid">

      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonio' -%}
          <article class="mtesti__card" {{ block.shopify_attributes }}>

            <div class="mtesti__stars" role="img" aria-label="5 de 5 estrellas">
              <span aria-hidden="true">★★★★★</span>
            </div>

            <div class="mtesti__quote-wrap">
              <span class="mtesti__quote-mark" aria-hidden="true">&ldquo;</span>
              <blockquote class="mtesti__quote">
                <p>{{ block.settings.quote }}</p>
              </blockquote>
            </div>

            <footer class="mtesti__attribution">
              <p class="mtesti__author">{{ block.settings.attribution }}</p>
              {%- if block.settings.service != blank -%}
                <p class="mtesti__service">{{ block.settings.service }}</p>
              {%- endif -%}
              <p class="mtesti__verified">
                <svg class="mtesti__verified-icon" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
                  <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                  <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                  <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                  <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                </svg>
                Reseña en Google
              </p>
            </footer>

          </article>
        {%- endif -%}
      {%- endfor -%}

      <aside class="mtesti__stats">
        <svg class="mtesti__google-g" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        </svg>

        <p class="mtesti__rating-number">{{ section.settings.rating }}</p>

        <div class="mtesti__stars mtesti__stars--lg" role="img" aria-label="4,9 de 5 estrellas">
          <span aria-hidden="true">★★★★★</span>
        </div>

        <p class="mtesti__review-count">
          Basado en {{ section.settings.review_count }} reseñas verificadas
        </p>

        <a
          href="{{ google_url }}"
          class="mtesti__google-cta maniqui-btn"
          {% unless section.settings.google_url == blank %}target="_blank" rel="noopener"{% endunless %}
        >{{ section.settings.cta_label }}</a>
      </aside>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Validación social",
  "tag": "div",
  "class": "section-maniqui-testimonios",
  "settings": [
    {
      "type": "header",
