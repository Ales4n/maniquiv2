{% comment %} MANIQUI: Banda de confianza — reduce fricción tras el hero — 2026-05-05 {% endcomment %}

<section class="mbanda" id="maniquiBanda" aria-label="Por qué Maniquí">
  <div class="mbanda__inner maniqui-container">
    {%- for block in section.blocks -%}
      {%- if block.type == 'item' -%}
        <div class="mbanda__item" {{ block.shopify_attributes }}>
          <svg class="mbanda__dot" width="6" height="6" viewBox="0 0 6 6" fill="none" aria-hidden="true">
            <circle cx="3" cy="3" r="3" fill="currentColor"/>
          </svg>
          <span class="mbanda__text">{{ block.settings.text }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Banda de confianza",
  "tag": "div",
  "class": "section-maniqui-banda",
  "blocks": [
    {
      "type": "item",
      "name": "Ítem de confianza",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Ítem de confianza"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banda de confianza",
      "blocks": [
        { "type": "item", "settings": { "text": "3 años en Marxalenes" } },
        { "type": "item", "settings": { "text": "5 estrellas en Google" } },
        { "type": "item", "settings": { "text": "Atención sin cita previa" } },
        { "type": "item", "settings": { "text": "Presupuesto al momento" } }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
/* ─── Banda de confianza ─── */
.section-maniqui-banda .mbanda {
  background: var(--warm-dark);
  padding: 24px 0;
  border-top: 1px solid rgba(196, 164, 107, 0.5);
  border-bottom: 1px solid rgba(196, 164, 107, 0.5);
}

.section-maniqui-banda .mbanda__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px 24px;
  max-width: 100%;
}

.section-maniqui-banda .mbanda__item {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  justify-content: center;
}

.section-maniqui-banda .mbanda__dot {
  color: var(--sage);
  flex-shrink: 0;
}

.section-maniqui-banda .mbanda__text {
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.03em;
  color: rgba(253,251,247,0.85);
  white-space: nowrap;
}

/* ─── Mobile ─── */
@media (max-width: 600px) {
  .section-maniqui-banda .mbanda__inner {
    gap: 10px 24px;
    justify-content: flex-start;
  }
  .section-maniqui-banda .mbanda__item {
    flex: 0 1 auto;
    justify-content: flex-start;
  }
  .section-maniqui-banda .mbanda__text {
    font-size: 12px;
    white-space: normal;
  }
}
{% endstylesheet %}
