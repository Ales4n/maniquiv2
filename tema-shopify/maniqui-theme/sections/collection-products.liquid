{% comment %} MANIQUI: Collection products — grid de servicios con precio y CTA a producto — 2026-05-27 {% endcomment %}

<section class="colp" id="collectionProducts">
  <div class="colp__inner maniqui-container">

    {%- if collection.products.size > 0 -%}
      <ul class="colp__grid" role="list">
        {%- for product in collection.products -%}
          <li class="colp__card">
            <a href="{{ product.url }}" class="colp__card-link" aria-label="{{ product.title | escape }}">
              <div class="colp__card-body">
                <span class="colp__price">{{ product.price_min | money_without_trailing_zeros }}</span>
                <h2 class="colp__name">{{ product.title }}</h2>
                {%- if product.description != blank -%}
                  <p class="colp__desc">{{ product.description | strip_html | truncate: 130 }}</p>
                {%- endif -%}
              </div>
              <span class="colp__arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p class="colp__empty">Sin arreglos disponibles en esta categoría por el momento.</p>
    {%- endif -%}

    {%- if section.settings.nota_wa != blank -%}
      <p class="colp__nota">{{ section.settings.nota_wa }}</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Collection products",
  "tag": "div",
  "class": "section-collection-products",
  "settings": [
    {
      "type": "text",
      "id": "nota_wa",
      "label": "Nota inferior (opcional)",
      "default": "¿Tu prenda tiene algo especial? Escríbenos por WhatsApp antes de contratar."
    }
  ],
  "presets": [
    { "name": "Collection products" }
  ]
}
{% endschema %}

{% stylesheet %}
/* ─── Collection products ─── */
.section-collection-products .colp {
  background: var(--cream-warm);
  padding: 64px 0 80px;
}
.section-collection-products .colp__inner {
  max-width: var(--container-max);
  margin: 0 auto;
}

/* ─── Grid ─── */
.section-collection-products .colp__grid {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

/* ─── Card ─── */
.section-collection-products .colp__card {
  display: flex;
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 8px;
  transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
}
.section-collection-products .colp__card:hover {
  border-color: var(--sage-line);
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(42, 37, 32, 0.08);
}

/* ─── Card link (toda la card clickable) ─── */
.section-collection-products .colp__card-link {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 28px 24px 24px;
  text-decoration: none;
  min-height: 160px;
}
.section-collection-products .colp__card-body {
  flex: 1;
}

/* ─── Precio ─── */
.section-collection-products .colp__price {
  display: block;
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  color: var(--sage);
  letter-spacing: 0.10em;
  text-transform: uppercase;
  margin-bottom: 10px;
}

/* ─── Nombre del arreglo ─── */
.section-collection-products .colp__name {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(1.25rem, 2vw, 1.5rem);
  line-height: 1.2;
  color: var(--warm-dark);
  margin: 0 0 12px;
}

/* ─── Descripción ─── */
.section-collection-products .colp__desc {
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.55;
  color: var(--text-2);
  margin: 0;
}

/* ─── Flecha ─── */
.section-collection-products .colp__arrow {
  display: flex;
  align-items: center;
  color: var(--sage);
  margin-top: 20px;
  transition: transform 200ms ease;
  flex-shrink: 0;
}
.section-collection-products .colp__card:hover .colp__arrow {
  transform: translateX(4px);
}

/* ─── Estados vacío y nota ─── */
.section-collection-products .colp__empty {
  font-family: var(--font-body);
  font-size: 15px;
  color: var(--text-muted);
  padding: 48px 0;
  text-align: center;
}
.section-collection-products .colp__nota {
  margin-top: 40px;
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.6;
  color: var(--text-muted);
  text-align: center;
}

/* ─── Tablet ─── */
@media (max-width: 1024px) {
  .section-collection-products .colp {
    padding: 48px 0 64px;
  }
}

/* ─── Mobile ─── */
@media (max-width: 600px) {
  .section-collection-products .colp {
    padding: 40px 0 48px;
  }
  .section-collection-products .colp__grid {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .section-collection-products .colp__card-link {
    min-height: 0;
    padding: 20px 20px 18px;
  }
  .section-collection-products .colp__name {
    font-size: 1.25rem;
  }
}
{% endstylesheet %}
