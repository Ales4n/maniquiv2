{% comment %} MANIQUI: Visita el taller — mapa, dirección, horario, callout Calendly — 2026-05-10 {% endcomment %}

{%- assign wa_phone = '34603305566' -%}
{%- assign wa_msg = 'Hola, necesito arreglar una prenda. ¿Me podéis dar precio?' | url_encode -%}
{%- assign wa_url = 'https://wa.me/' | append: wa_phone | append: '?text=' | append: wa_msg -%}

<section class="mtaller" id="maniquiTaller">
  <div class="mtaller__inner maniqui-container">

    <header class="mtaller__header">
      <h2 class="mtaller__headline">
        {{ section.settings.headline }}
        {%- if section.settings.headline_em != blank -%}
          <em class="mtaller__headline-em">{{ section.settings.headline_em }}</em>
        {%- endif -%}
      </h2>
      {%- if section.settings.subheadline != blank -%}
        <p class="mtaller__sub">{{ section.settings.subheadline }}</p>
      {%- endif -%}
    </header>

    <div class="mtaller__grid">

      <div class="mtaller__map-wrap">
        {%- if section.settings.maps_embed_url != blank -%}
          <iframe
            class="mtaller__map"
            src="{{ section.settings.maps_embed_url }}"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa — Taller Maniquí, Avinguda de la Constitució 94, Valencia"
            allowfullscreen
          ></iframe>
        {%- else -%}
          <div class="mtaller__map-placeholder" aria-hidden="true"></div>
        {%- endif -%}
      </div>

      <div class="mtaller__info">

        <div class="mtaller__info-row">
          <p class="mtaller__label">Dirección</p>
          <p class="mtaller__value">{{ section.settings.address_line1 }}</p>
          {%- if section.settings.address_line2 != blank -%}
            <p class="mtaller__detail">{{ section.settings.address_line2 }}</p>
          {%- endif -%}
        </div>

        <div class="mtaller__info-row">
          <p class="mtaller__label">Horario</p>
          <p class="mtaller__value">{{ section.settings.schedule_days }}</p>
          {%- if section.settings.schedule_hours != blank -%}
            <p class="mtaller__detail">{{ section.settings.schedule_hours }}</p>
          {%- endif -%}
        </div>

        {%- if section.settings.contact_phone != blank or section.settings.contact_email != blank -%}
          <div class="mtaller__info-row">
            <p class="mtaller__label">Contacto directo</p>
            {%- if section.settings.contact_phone != blank -%}
              {%- assign phone_href = section.settings.contact_phone | remove: ' ' -%}
              <a href="tel:{{ phone_href }}" class="mtaller__value mtaller__contact-link">
                {{- section.settings.contact_phone -}}
              </a>
            {%- endif -%}
            {%- if section.settings.contact_email != blank -%}
              <a href="mailto:{{ section.settings.contact_email }}" class="mtaller__detail mtaller__contact-link">
                {{- section.settings.contact_email -}}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="mtaller__ctas">
          <a
            href="{{ section.settings.cta_taller_url }}"
            class="maniqui-btn mtaller__btn-taller"
            target="_blank"
            rel="noopener"
          >{{ section.settings.cta_taller_label }}</a>
          <a
            href="{{ wa_url }}"
            class="maniqui-btn maniqui-btn--wa"
            target="_blank"
            rel="noopener"
          >{{ section.settings.cta_wa_label }}</a>
        </div>

      </div>
    </div>

    {%- if section.settings.callout_text != blank -%}
      <div class="mtaller__callout">
        <p class="mtaller__callout-text">{{ section.settings.callout_text }}</p>
        {%- assign calendly_url = section.settings.callout_cta_url | default: '#' -%}
        <a
          href="{{ calendly_url }}"
          class="mtaller__callout-cta"
          {% unless section.settings.callout_cta_url == blank %}target="_blank" rel="noopener"{% endunless %}
        >{{ section.settings.callout_cta_label }}</a>
      </div>
    {%- endif -%}

  </div>
</section>

