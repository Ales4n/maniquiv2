{% comment %} MANIQUI: Cart drawer — slide-in, multi-prenda, foto miniatura — 2026-06-12 {% endcomment %}

<div id="maniquiCartDrawer" class="mcd" aria-hidden="true">
  <div class="mcd__overlay" id="maniquiCartOverlay"></div>
  <div class="mcd__panel" role="dialog" aria-modal="true" aria-labelledby="mcd-title">

    <div class="mcd__header">
      <h2 class="mcd__title" id="mcd-title">Tu pedido</h2>
      <button class="mcd__close" id="maniquiCartClose" aria-label="Cerrar carrito" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M6 6L18 18M6 18L18 6"/>
        </svg>
      </button>
    </div>

    <div class="mcd__body" id="maniquiCartBody">
      <!-- ítems renderizados via JS tras openCartDrawer() -->
    </div>

    <div class="mcd__footer" id="maniquiCartFooter">
      <a href="/pages/contratar" class="mcd__add-more">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M12 5v14M5 12h14"/>
        </svg>
        Añadir otra prenda
      </a>
      <div class="mcd__total" id="maniquiCartTotal"></div>
      <a href="/checkout" class="maniqui-btn mcd__checkout">
        Pagar
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"/>
        </svg>
      </a>
    </div>

  </div>
</div>

{% stylesheet %}
/* ─── Cart Drawer ─── */
.mcd {
  position: fixed;
  inset: 0;
  z-index: 9100;
  pointer-events: none;
  visibility: hidden;
}
.mcd.is-open {
  pointer-events: auto;
  visibility: visible;
}
.mcd__overlay {
  position: absolute;
  inset: 0;
  background: rgba(42, 37, 32, 0.40);
  opacity: 0;
  transition: opacity 280ms ease;
  cursor: pointer;
}
.mcd.is-open .mcd__overlay { opacity: 1; }

.mcd__panel {
  position: absolute;
  top: 0;
  right: 0;
  width: min(440px, 100vw);
  height: 100%;
  background: var(--cream);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 280ms ease;
  overflow: hidden;
}
.mcd.is-open .mcd__panel { transform: translateX(0); }

.mcd__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24px 28px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.mcd__title {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: 22px;
  color: var(--warm-dark);
  margin: 0;
}
.mcd__close {
  color: var(--text-muted);
  padding: 4px;
  display: flex;
  align-items: center;
  transition: color 200ms ease;
}
.mcd__close:hover { color: var(--warm-dark); }

.mcd__body {
  flex: 1;
  overflow-y: auto;
  padding: 0 28px;
  -webkit-overflow-scrolling: touch;
}
.mcd__empty {
  text-align: center;
  padding: 56px 0;
  color: var(--text-muted);
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.6;
}

/* ─── Línea de ítem ─── */
.mcd__item {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  padding: 20px 0;
  border-bottom: 1px solid var(--border);
}
.mcd__item:last-child { border-bottom: none; }

.mcd__item-thumb {
  width: 72px;
  height: 72px;
  border-radius: 6px;
  overflow: hidden;
  background: var(--border);
  flex-shrink: 0;
}
.mcd__item-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.mcd__item-thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
}
.mcd__item-info { flex: 1; min-width: 0; }
.mcd__item-title {
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  color: var(--warm-dark);
  margin: 0 0 5px;
  line-height: 1.3;
}
.mcd__item-instrucciones {
  font-family: var(--font-body);
  font-size: 12px;
  color: var(--text-muted);
  margin: 0 0 8px;
  line-height: 1.5;
  font-style: italic;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.mcd__item-price {
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  color: var(--warm-dark);
}

/* ─── Footer ─── */
.mcd__footer {
  border-top: 1px solid var(--border);
  padding: 20px 28px 32px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.mcd__add-more {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--sage-dark);
  text-decoration: none;
  transition: color 200ms ease;
  align-self: flex-start;
}
.mcd__add-more:hover { color: var(--sage); }
.mcd__total {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 500;
  color: var(--warm-dark);
}
.mcd__checkout {
  background: var(--warm-dark);
  color: var(--cream);
  border-color: var(--warm-dark);
  justify-content: center;
  width: 100%;
}
.mcd__checkout:hover {
  background: #1d1916;
  border-color: #1d1916;
  transform: translateY(-1px);
}

@media (max-width: 600px) {
  .mcd__panel { width: 100vw; }
  .mcd__header,
  .mcd__body,
  .mcd__footer { padding-left: 20px; padding-right: 20px; }
}
{% endstylesheet %}

<script>
(function () {
  var drawer   = document.getElementById('maniquiCartDrawer');
  var overlay  = document.getElementById('maniquiCartOverlay');
  var body     = document.getElementById('maniquiCartBody');
  var totalEl  = document.getElementById('maniquiCartTotal');
  var closeBtn = document.getElementById('maniquiCartClose');

  if (!drawer) return;

  function openCartDrawer() {
    drawer.classList.add('is-open');
    drawer.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    refreshCart();
  }

  function closeCartDrawer() {
    drawer.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  if (overlay) overlay.addEventListener('click', closeCartDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeCartDrawer);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeCartDrawer();
  });

  function formatMoney(cents) {
    return (cents / 100).toLocaleString('es-ES', { style: 'currency', currency: 'EUR' });
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function refreshCart() {
    fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        if (!body) return;
        if (!cart.items || cart.items.length === 0) {
          body.innerHTML = '<p class="mcd__empty">Tu carrito está vacío.<br>Elige un arreglo para empezar.</p>';
          if (totalEl) totalEl.textContent = '';
          return;
        }

        var html = '';
        cart.items.forEach(function (item) {
          var fotoUrl   = item.properties && item.properties['Foto'];
          var instrText = item.properties && item.properties['Instrucciones'];

          var thumbHtml;
          if (fotoUrl && /^https?:\/\//.test(fotoUrl)) {
            thumbHtml = '<img src="' + escapeHtml(fotoUrl) + '" alt="Foto prenda" loading="lazy">';
          } else {
            thumbHtml = '<div class="mcd__item-thumb-placeholder">'
              + '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 16l5-5 4 4 3-3 6 6"/></svg>'
              + '</div>';
          }

          var instrHtml = instrText
            ? '<p class="mcd__item-instrucciones">' + escapeHtml(instrText) + '</p>'
            : '';

          html += '<div class="mcd__item">'
            + '<div class="mcd__item-thumb">' + thumbHtml + '</div>'
            + '<div class="mcd__item-info">'
            + '<p class="mcd__item-title">' + escapeHtml(item.product_title) + '</p>'
            + instrHtml
            + '<p class="mcd__item-price">' + formatMoney(item.final_line_price) + '</p>'
            + '</div>'
            + '</div>';
        });

        body.innerHTML = html;
        if (totalEl) totalEl.textContent = 'Total: ' + formatMoney(cart.total_price);
      })
      .catch(function () {
        if (body) body.innerHTML = '<p class="mcd__empty">No se pudo cargar el carrito.</p>';
      });
  }

  /* Exponer globalmente para product-main y cualquier otro add-to-cart */
  window.openCartDrawer = openCartDrawer;
  window.closeCartDrawer = closeCartDrawer;
})();
</script>

