{%- comment %} MANIQUI: Botón flotante WhatsApp — global, aparece tras 300px scroll — 2026-05-11 {%- endcomment %}

{%- assign wa_phone = '34603305566' -%}
{%- assign wa_msg = 'Hola, necesito arreglar una prenda. ¿Me podéis dar precio?' | url_encode -%}
{%- assign wa_url = 'https://wa.me/' | append: wa_phone | append: '?text=' | append: wa_msg -%}

<a
  href="{{ wa_url }}"
  class="wa-float"
  id="waFloat"
  target="_blank"
  rel="noopener"
  aria-label="Contactar por WhatsApp"
>
  <svg class="wa-float__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zm-5.421 7.403h-.004a10.87 10.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a10.86 10.86 0 01-1.184-5.37c.002-5.898 4.803-10.697 10.706-10.697 2.86 0 5.54 1.115 7.552 3.13a10.635 10.635 0 013.126 7.566c-.002 5.897-4.803 10.696-10.7 10.696z"/>
  </svg>
</a>

<style>
.wa-float {
  position: fixed;
  bottom: 32px;
  right: 32px;
  z-index: 9000;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--whatsapp, #25D366);
  color: #fff;
  text-decoration: none;
  box-shadow: 0 4px 16px rgba(37, 211, 102, 0.45);
  opacity: 0;
  transform: scale(0.75);
  pointer-events: none;
  transition: opacity 350ms ease, transform 350ms ease, background var(--tr-fast, 200ms ease), box-shadow var(--tr-fast, 200ms ease);
}

.wa-float.is-visible {
  opacity: 1;
  transform: scale(1);
  pointer-events: auto;
}

.wa-float:hover {
  background: var(--whatsapp-dark, #128C7E);
  box-shadow: 0 6px 22px rgba(37, 211, 102, 0.55);
  transform: scale(1.08);
}

.wa-float:focus-visible {
  outline: 3px solid var(--whatsapp, #25D366);
  outline-offset: 3px;
}

.wa-float__icon {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
}

@media (min-width: 601px) {
  .wa-float {
    display: none;
  }
}

@media (max-width: 600px) {
  .wa-float {
    bottom: 20px;
    right: 20px;
    width: 52px;
    height: 52px;
  }
  .wa-float__icon {
    width: 26px;
    height: 26px;
  }
}
</style>

<script>
(function () {
  var btn = document.getElementById('waFloat');
  if (!btn) return;
  function show() {
    btn.classList.add('is-visible');
    window.removeEventListener('scroll', onScroll);
  }
  function onScroll() {
    if (window.scrollY > 300) show();
  }
  if (window.scrollY > 300) {
    show();
  } else {
    window.addEventListener('scroll', onScroll, { passive: true });
  }
}());
</script>
