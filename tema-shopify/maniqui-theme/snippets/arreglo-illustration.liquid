{% comment %} MANIQUI: Ilustraciones de arreglo — snippet centralizado, 12 keys — 2026-06-01 {% endcomment %}

{%- comment %}
  Parámetros:
    product  — objeto Shopify product (opcional; resuelve key desde product.handle)
    key      — string clave (opcional; se usa directamente si se pasa)
    size     — 'sm' (~44px) | 'lg' (~140px)
{%- endcomment -%}

{%- comment %} Resolver key desde product.handle si no viene explícito {%- endcomment -%}
{%- unless key -%}
  {%- case product.handle -%}
    {%- when 'bajos-vaquero-normal', 'bajos-vaquero-especial', 'bajos-pantalon-vestir-invisible', 'bajos-pantalon-vestir-mano' -%}
      {%- assign key = 'bajo-pantalon' -%}
    {%- when 'bajos-vestido', 'bajos-vestido-forro', 'bajos-vestido-mano', 'bajos-vestido-multicapa', 'bajos-vestido-repulgo' -%}
      {%- assign key = 'bajo-vestido' -%}
    {%- when 'cremallera-blusa-camisa', 'cremallera-invisible', 'cremallera-pantalon', 'cremallera-metalica' -%}
      {%- assign key = 'cremallera' -%}
    {%- when 'cremallera-chaqueta' -%}
      {%- assign key = 'cremallera-chaqueta' -%}
    {%- when 'ajustar-vestido-lados', 'meter-lados-camisa', 'meter-lados-camisa-forro' -%}
      {%- assign key = 'ajuste-lados' -%}
    {%- when 'ajustar-chaqueta-lado', 'ajustar-chaqueta-lado-forro', 'ajustar-espalda-chaqueta' -%}
      {%- assign key = 'ajuste-chaqueta' -%}
    {%- when 'acortar-mangas-chaqueta-sin-apertura', 'acortar-mangas-chaqueta-con-apertura', 'estrechar-mangas-chaqueta', 'cortar-mangas-vestido' -%}
      {%- assign key = 'manga' -%}
    {%- when 'tirantes-sin-forro', 'tirantes-con-forro' -%}
      {%- assign key = 'tirantes' -%}
    {%- when 'ajuste-cintura' -%}
      {%- assign key = 'cintura' -%}
    {%- when 'pinzas' -%}
      {%- assign key = 'pinzas' -%}
    {%- when 'zurcido' -%}
      {%- assign key = 'zurcido' -%}
    {%- when 'botones' -%}
      {%- assign key = 'boton' -%}
    {%- else -%}
      {%- assign key = 'bajo-pantalon' -%}
  {%- endcase -%}
{%- endunless -%}

{%- comment %} Dimensiones y stroke-width según tamaño {%- endcomment -%}
{%- if size == 'sm' -%}
  {%- assign svgW = 44 -%}
  {%- assign svgH = 58 -%}
  {%- assign sw = '6' -%}
{%- else -%}
  {%- assign svgW = 140 -%}
  {%- assign svgH = 184 -%}
  {%- assign sw = '2' -%}
{%- endif -%}

{%- case key -%}

{%- when 'bajo-pantalon' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Pantalón con la línea de bajo marcada">
  <path d="M46 16 L114 16 L112 188 L88 188 L80 104 L72 188 L48 188 Z"/>
  <path d="M46 34 L114 34"/>
  <line x1="50" y1="166" x2="74" y2="166" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <line x1="86" y1="166" x2="110" y2="166" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'bajo-vestido' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Vestido con la línea de bajo marcada">
  <path d="M62 22 Q80 32 98 22 L110 44 L122 180 L38 180 L50 44 Z"/>
  <line x1="46" y1="166" x2="114" y2="166" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'cremallera' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Blusa con cremallera central marcada">
  <path d="M48 36 Q80 22 112 36 L112 178 L48 178 Z"/>
  <path d="M68 36 Q80 50 92 36"/>
  <path d="M74 44 L80 38 L86 44" stroke="var(--terracotta)"/>
  <line x1="80" y1="44" x2="80" y2="164" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'cremallera-chaqueta' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Chaqueta con cremallera frontal marcada">
  <path d="M40 22 L120 22 L120 182 L40 182 Z"/>
  <path d="M80 44 L56 72 L40 54"/>
  <path d="M80 44 L104 72 L120 54"/>
  <path d="M74 66 L80 60 L86 66" stroke="var(--terracotta)"/>
  <line x1="80" y1="66" x2="80" y2="170" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'ajuste-lados' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Prenda con líneas de ajuste de lados marcadas">
  <path d="M50 26 Q80 16 110 26 L112 180 L48 180 Z"/>
  <path d="M68 26 Q80 38 92 26"/>
  <line x1="62" y1="72" x2="58" y2="166" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <line x1="98" y1="72" x2="102" y2="166" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'ajuste-chaqueta' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Chaqueta con ajuste de costado marcado">
  <path d="M40 22 L120 22 L120 182 L40 182 Z"/>
  <path d="M80 44 L56 70 L40 52"/>
  <path d="M80 44 L104 70 L120 52"/>
  <line x1="56" y1="78" x2="52" y2="168" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <line x1="104" y1="78" x2="108" y2="168" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'manga' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Manga con línea de acortamiento marcada">
  <path d="M44 22 L116 22 L104 178 L56 178 Z"/>
  <path d="M58 166 L102 166"/>
  <line x1="54" y1="148" x2="106" y2="148" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'tirantes' -%}
