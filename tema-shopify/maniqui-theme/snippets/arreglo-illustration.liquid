  <path d="M48 68 L112 68 L118 182 L42 182 Z"/>
  <line x1="58" y1="22" x2="66" y2="22" stroke="var(--terracotta)"/>
  <line x1="94" y1="22" x2="102" y2="22" stroke="var(--terracotta)"/>
  <line x1="62" y1="22" x2="58" y2="68" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <line x1="98" y1="22" x2="102" y2="68" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'cintura' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Prenda con ajuste de cintura marcado">
  <path d="M52 22 Q80 16 108 22 L114 108 L108 184 L52 184 L46 108 Z"/>
  <path d="M68 22 Q80 34 92 22"/>
  <line x1="46" y1="108" x2="114" y2="108" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'pinzas' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Prenda con pinzas marcadas">
  <path d="M50 26 Q80 16 110 26 L112 178 L48 178 Z"/>
  <path d="M68 26 Q80 38 92 26"/>
  <path d="M62 55 L68 100 L74 55" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <path d="M86 55 L92 100 L98 55" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'zurcido' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Tela con puntadas de zurcido marcadas">
  <path d="M28 30 L132 30 L132 180 L28 180 Z"/>
  <line x1="28" y1="30" x2="28" y2="180" stroke="var(--sage)" opacity="0.3"/>
  <path d="M52 78 L76 102 M76 78 L52 102" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <path d="M84 78 L108 102 M108 78 L84 102" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <path d="M52 116 L76 140 M76 116 L52 140" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <path d="M84 116 L108 140 M108 116 L84 140" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- when 'boton' -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Botón con agujeros e hilo marcados">
  <circle cx="80" cy="105" r="40"/>
  <circle cx="68" cy="98" r="5"/>
  <circle cx="92" cy="98" r="5"/>
  <circle cx="68" cy="112" r="5"/>
  <circle cx="92" cy="112" r="5"/>
  <line x1="68" y1="98" x2="92" y2="112" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <line x1="92" y1="98" x2="68" y2="112" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- else -%}
{%- comment %} Fallback genérico: bajo-pantalon {%- endcomment -%}
<svg width="{{ svgW }}" height="{{ svgH }}" viewBox="0 0 160 210" fill="none" stroke="var(--sage)" stroke-width="{{ sw }}" stroke-linejoin="round" stroke-linecap="round" role="img" aria-label="Prenda de ropa">
  <path d="M46 16 L114 16 L112 188 L88 188 L80 104 L72 188 L48 188 Z"/>
  <path d="M46 34 L114 34"/>
  <line x1="50" y1="166" x2="74" y2="166" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
  <line x1="86" y1="166" x2="110" y2="166" stroke="var(--terracotta)" stroke-dasharray="4 4"/>
</svg>

{%- endcase -%}
